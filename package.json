{
  "name": "my-portfolio",
  "version": "3.1.0",
  "scripts": {
    "ng": "ng",
    "config": "node scripts/set-env.mjs",
    "start": "ng serve",
    "dev": "ng serve --watch --host 0.0.0.0",
    "dev:remote": "ng serve --configuration development --watch --host 0.0.0.0",
    "local": "ng serve --c local-development --watch --host 0.0.0.0",
    "build": "ng build",
    "build:prod": "ng build --configuration production --base-href /My-Portfolio/",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --karma-config ./karma.conf.js",
    "serve:ssr:My-Portfolio": "node dist/my-portfolio/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.25",
    "@angular/cdk": "^19.1.0",
    "@angular/common": "^20.3.25",
    "@angular/compiler": "^20.3.25",
    "@angular/core": "^20.3.25",
    "@angular/forms": "^20.3.25",
    "@angular/platform-browser": "^20.3.25",
    "@angular/platform-browser-dynamic": "^20.3.25",
    "@angular/platform-server": "^20.3.25",
    "@angular/router": "^20.3.25",
    "@angular/ssr": "^20.3.28",
    "@coreui/angular": "5.4.1",
    "@coreui/angular-chartjs": "~5.6.4",
    "@coreui/chartjs": "^4.2.0",
    "@coreui/coreui": "~5.3.1",
    "@coreui/icons": "^3.0.1",
    "@coreui/icons-angular": "5.4.1",
    "@coreui/utils": "^2.0.2",
    "@ngx-pwa/local-storage": "^19.0.0",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "browser-image-compression": "^2.0.2",
    "chart.js": "^4.5.1",
    "express": "^4.18.2",
    "husky": "^9.1.7",
    "ng-recaptcha": "^13.2.1",
    "ngx-scrollbar": "^18.0.0",
    "ngx-toastr": "^19.0.0",
    "prettier": "^3.5.1",
    "rxjs": "~7.8.0",
    "swiper": "^11.2.4",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.28",
    "@angular/cli": "^20.3.28",
    "@angular/compiler-cli": "^20.3.25",
    "@eslint/js": "^9.20.0",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/jquery": "^3.5.32",
    "@types/node": "^18.18.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^50.6.3",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "globals": "^15.15.0",
    "jasmine-core": "~5.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.24.0"
  }
}