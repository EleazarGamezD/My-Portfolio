{
  "name": "my-portfolio",
  "version": "3.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration local-development --host 0.0.0.0",
    "dev": "ng serve --configuration local-development --host 0.0.0.0",
    "dev:remote": "ng serve --configuration development --host 0.0.0.0",
    "local": "ng serve --configuration local-development --host 0.0.0.0",
    "build": "ng build",
    "build:prod": "ng build --configuration production --base-href /My-Portfolio/",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --karma-config ./karma.conf.js",
    "serve:ssr:My-Portfolio": "node dist/my-portfolio/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.6",
    "@angular/cdk": "21.0.5",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/localize": "^21.0.6",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/ssr": "^21.0.4",
    "@coreui/angular": "^5.5.24",
    "@coreui/coreui": "~5.4.3",
    "@coreui/icons": "^3.0.1",
    "@coreui/icons-angular": "^5.6.5",
    "@ngx-pwa/local-storage": "^21.0.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.11.3",
    "browser-image-compression": "^2.0.2",
    "express": "^5.1.0",
    "husky": "^9.1.7",
    "ng-recaptcha": "^13.2.1",
    "ngx-scrollbar": "^19.1.0",
    "ngx-toastr": "^20.0.5",
    "prettier": "^3.5.1",
    "rxjs": "~7.8.0",
    "swiper": "^11.2.4",
    "tslib": "^2.3.0",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@eslint/js": "^9.20.0",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/jquery": "^3.5.32",
    "@types/node": "^20.17.19",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^50.6.3",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "globals": "^15.15.0",
    "jasmine-core": "~5.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.24.0"
  }
