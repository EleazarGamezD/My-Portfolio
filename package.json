{
  "name": "my-portfolio",
  "version": "3.1.0",
  "scripts": {
    "ng": "ng",
    "config": "node scripts/set-env.mjs",
    "start": "ng serve",
    "dev": "ng serve --watch --host 0.0.0.0",
    "dev:remote": "ng serve --configuration development --watch --host 0.0.0.0",
    "local": "ng serve --c local-development --watch --host 0.0.0.0",
    "build": "ng build",
    "build:prod": "ng build --configuration production --base-href /My-Portfolio/",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --karma-config ./karma.conf.js",
    "serve:ssr:My-Portfolio": "node dist/my-portfolio/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.17",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/platform-browser": "^21.2.17",
    "@angular/platform-browser-dynamic": "^21.2.17",
    "@angular/platform-server": "^21.2.17",
    "@angular/router": "^21.2.17",
    "@angular/ssr": "^21.2.15",
    "@coreui/angular": "5.6.24",
    "@coreui/angular-chartjs": "~5.6.24",
    "@coreui/chartjs": "^4.2.0",
    "@coreui/coreui": "~5.8.0",
    "@coreui/icons": "^3.1.0",
    "@coreui/icons-angular": "5.6.24",
    "@coreui/utils": "^2.0.2",
    "@ngx-pwa/local-storage": "^22.0.0",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "browser-image-compression": "^2.0.2",
    "chart.js": "^4.5.1",
    "express": "^4.18.2",
    "husky": "^9.1.7",
    "ng-recaptcha": "^13.2.1",
    "ngx-scrollbar": "^19.1.5",
    "ngx-toastr": "^20.0.5",
    "prettier": "^3.5.1",
    "rxjs": "~7.8.0",
    "swiper": "^11.2.4",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.15",
    "@angular/cli": "^21.2.15",
    "@angular/compiler-cli": "^21.2.17",
    "@eslint/js": "^9.20.0",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/jquery": "^3.5.32",
    "@types/node": "^18.18.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^50.6.3",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "globals": "^15.15.0",
    "jasmine-core": "~5.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.24.0"
  }
}
